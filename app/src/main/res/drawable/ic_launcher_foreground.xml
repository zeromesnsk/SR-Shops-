<?xml version="1.0" encoding="utf-8"?>
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- Central Glowing Shield Shadow -->
    <path
        android:pathData="M54,22 L82,38 L82,70 L54,86 L26,70 L26,38 Z"
        android:fillColor="#33000000" />

    <!-- Outer Golden Shield Frame -->
    <path
        android:pathData="M54,24 L80,39 L80,69 L54,84 L28,69 L28,39 Z"
        android:strokeWidth="3"
        android:strokeLineCap="round"
        android:strokeLineJoin="round">
        <aapt:attr name="android:strokeColor">
            <gradient
                android:type="linear"
                android:startX="28"
                android:startY="24"
                android:endX="80"
                android:endY="84">
                <item android:offset="0.0" android:color="#FDE047" /> <!-- Neon yellow-gold -->
                <item android:offset="0.5" android:color="#CA8A04" /> <!-- Warm gold -->
                <item android:offset="1.0" android:color="#EAB308" /> <!-- Standard gold -->
            </gradient>
        </aapt:attr>
    </path>

    <!-- Luxury Shopping Bag Handle Curve -->
    <path
        android:pathData="M42,39 C42,30 66,30 66,39"
        android:strokeWidth="2.5"
        android:strokeLineCap="round">
        <aapt:attr name="android:strokeColor">
            <gradient
                android:type="linear"
                android:startX="42"
                android:startY="30"
                android:endX="66"
                android:endY="40">
                <item android:offset="0.0" android:color="#FFFFFF" />
                <item android:offset="1.0" android:color="#CA8A04" />
            </gradient>
        </aapt:attr>
    </path>

    <!-- Stylized Monogram Letter "S" Ribbon inside Shield -->
    <path
        android:pathData="M40,48 C40,44 48,44 48,48 C48,52 40,54 40,59 C40,64 50,64 50,60"
        android:strokeWidth="4"
        android:strokeLineCap="round"
        android:strokeLineJoin="round"
        android:fillColor="#00000000">
        <aapt:attr name="android:strokeColor">
            <gradient
                android:type="linear"
                android:startX="40"
                android:startY="44"
                android:endX="50"
                android:endY="64">
                <item android:offset="0.0" android:color="#FFFFFF" />
                <item android:offset="1.0" android:color="#E2E8F0" />
            </gradient>
        </aapt:attr>
    </path>

    <!-- Stylized Monogram Letter "R" Ribbon inside Shield -->
    <path
        android:pathData="M58,45 L58,63 M58,45 C64,45 66,51 58,53 M58,53 L66,63"
        android:strokeWidth="4"
        android:strokeLineCap="round"
        android:strokeLineJoin="round"
        android:fillColor="#00000000">
        <aapt:attr name="android:strokeColor">
            <gradient
                android:type="linear"
                android:startX="58"
                android:startY="45"
                android:endX="66"
                android:endY="63">
                <item android:offset="0.0" android:color="#FDE047" />
                <item android:offset="1.0" android:color="#EAB308" />
            </gradient>
        </aapt:attr>
    </path>

    <!-- Small Sparkle Star (Elegant Touch) -->
    <path
        android:pathData="M72,32 L74,35 L77,32 L74,29 Z"
        android:fillColor="#FFFFFF" />
</vector>
